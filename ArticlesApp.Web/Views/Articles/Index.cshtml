@model List<Article>
@{
    ViewData["Title"] = "Articles";
}

<div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
    <h1 class="text-3xl font-black text-gray-900 leading-none">Articles</h1>

    <form method="get" asp-action="Search" class="relative group">
        <i class="bi bi-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-blue-500 transition-colors"></i>
        <input type="text" name="query" placeholder="Search articles..."
               class="pl-10 pr-4 py-2 border border-gray-200 rounded-xl w-full md:w-80 focus:ring-2 focus:ring-blue-100 focus:border-blue-400 outline-none transition-all shadow-sm" />
    </form>
</div>

@if (Model == null || !Model.Any())
{
    <div class="text-center py-20 bg-white rounded-2xl border-2 border-dashed border-gray-200">
        <i class="bi bi-journal-x text-5xl text-gray-300"></i>
        <p class="mt-4 text-gray-500">No articles found matching your criteria.</p>
    </div>
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        @foreach (var article in Model)
        {
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow flex flex-col">
                <div class="p-6 flex-grow">
                    <div class="flex items-center gap-2 mb-3">
                        <a asp-action="ByTag" asp-route-tag="@article.Tag"
                           class="px-2 py-1 bg-blue-50 text-blue-600 text-xs font-bold uppercase rounded-md tracking-wider hover:bg-blue-100">
                            @article.Tag
                        </a>
                    </div>
                    <h2 class="text-xl font-bold text-gray-800 mb-3 leading-tight hover:text-blue-600 transition-colors">
                        <a asp-action="Details" asp-route-id="@article.Id">@article.Title</a>
                    </h2>
                    <p class="text-gray-600 text-sm line-clamp-3">
                        @article.Content
                    </p>
                </div>
                <div class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex justify-between items-center">
                    <a asp-action="Details" asp-route-id="@article.Id" class="text-sm font-semibold text-blue-600 hover:text-blue-800 flex items-center gap-1">
                        Read more <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        }
    </div>
}

@if (ViewBag.TotalPages > 1)
{
    <div class="mt-12 flex justify-center items-center gap-2">

        @if (ViewBag.Page > 1)
        {
            <a asp-action="Index" asp-route-page="@(ViewBag.Page - 1)"
               class="p-2 w-10 h-10 flex items-center justify-center bg-white border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors text-gray-600 shadow-sm">
                <i class="bi bi-chevron-left"></i>
            </a>
        }
        else
        {
            <span class="p-2 w-10 h-10 flex items-center justify-center bg-gray-50 border border-gray-100 rounded-lg text-gray-300 cursor-not-allowed">
                <i class="bi bi-chevron-left"></i>
            </span>
        }

        <span class="px-4 py-2 bg-blue-600 text-white rounded-lg font-bold shadow-sm shadow-blue-200">
            @ViewBag.Page <span class="text-blue-200 font-normal mx-1 text-xs">of</span> @ViewBag.TotalPages
        </span>

        @if (ViewBag.Page < ViewBag.TotalPages)
        {
            <a asp-action="Index" asp-route-page="@(ViewBag.Page + 1)"
               class="p-2 w-10 h-10 flex items-center justify-center bg-white border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors text-gray-600 shadow-sm">
                <i class="bi bi-chevron-right"></i>
            </a>
        }
        else
        {
            <span class="p-2 w-10 h-10 flex items-center justify-center bg-gray-50 border border-gray-100 rounded-lg text-gray-300 cursor-not-allowed">
                <i class="bi bi-chevron-right"></i>
            </span>
        }
    </div>
}