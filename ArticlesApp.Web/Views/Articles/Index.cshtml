@model List<Article>

<h1 class="text-2xl font-bold mb-4">Articles</h1>

<form method="get" asp-action="Search" class="mb-6 flex gap-2">
    <input type="text" name="query" placeholder="Search..."
           class="border p-2 rounded w-64" />
    <button class="bg-blue-500 text-white px-4 py-2 rounded">Search</button>
</form>

@if (Model == null || !Model.Any())
{
    <p>No articles found</p>
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        @foreach (var article in Model)
        {
            <div class="bg-white p-4 rounded shadow">
                <h2 class="font-bold text-lg">@article.Title</h2>

                <p class="text-gray-600 mt-2">
                    @(article.Content.Length > 100
                                ? article.Content.Substring(0, 100) + "..."
                                : article.Content)
        </p>

                <div class="mt-3 text-sm text-gray-500">
                    Tag:
                    <a asp-action="ByTag" asp-route-tag="@article.Tag"
                       class="text-blue-500">@article.Tag</a>
                </div>

                <a asp-action="Details" asp-route-id="@article.Id"
                   class="inline-block mt-4 text-blue-600">
                    Read more →
                </a>
            </div>
        }
    </div>
}

<div class="mt-6 flex items-center gap-4">

    @if (ViewBag.Page > 1)
    {
        <a asp-action="Index" asp-route-page="@(ViewBag.Page - 1)"
           class="px-3 py-1 bg-gray-300 rounded">Prev</a>
    }

    <span>Page @ViewBag.Page</span>

    <a asp-action="Index" asp-route-page="@(ViewBag.Page + 1)"
       class="px-3 py-1 bg-gray-300 rounded">Next</a>

</div>