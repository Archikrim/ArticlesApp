@model List<Article>

<h1>Articles</h1>

<form method="get" asp-action="Search">
    <input type="text" name="query" placeholder="Search..." />
    <button type="submit">Search</button>
</form>

@if (Model == null || !Model.Any())
{
    <p>No articles found</p>
}
else
{
    <ul>
        @foreach (var article in Model)
        {
            <li>
                <a asp-action="Details" asp-route-id="@article.Id">
                    @article.Title
                </a>
                (Tag: <a asp-action="ByTag" asp-route-tag="@article.Tag">@article.Tag</a>)
            </li>
        }
    </ul>
}

@{
    int totalPages = (int)Math.Ceiling((double)ViewBag.TotalCount / ViewBag.PageSize);
}

<div style="margin-top:20px;">

    @if (ViewBag.Page > 1)
    {
        <a asp-action="Index" asp-route-page="@(ViewBag.Page - 1)">⬅ Prev</a>
    }

    <span style="margin:0 10px;">
        Page @ViewBag.Page of @totalPages
    </span>

    @if (ViewBag.Page < totalPages)
    {
        <a asp-action="Index" asp-route-page="@(ViewBag.Page + 1)">Next ➡</a>
    }

</div>