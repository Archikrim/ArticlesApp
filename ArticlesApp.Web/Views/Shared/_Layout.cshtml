<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ArticlesApp.Web</title>
    <script type="importmap"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ArticlesApp.Web.styles.css" asp-append-version="true" />
</head>
<body class="bg-gray-100">

    <nav class="bg-white shadow mb-6">
        <div class="container mx-auto px-4 py-3 flex gap-6">
            <a class="font-bold text-lg" asp-controller="Home" asp-action="Index">🏠 Home</a>
            <a asp-controller="Articles" asp-action="Index">📄 Articles</a>
            <a asp-controller="Products" asp-action="Index">🛒 Products</a>
        </div>
    </nav>

    <div class="container mx-auto px-4">
        @RenderBody()
    </div>

</body>
</html>
