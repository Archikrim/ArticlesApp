<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ArticlesApp.Web</title>
    <script type="importmap"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ArticlesApp.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="bg-gray-100">

    <nav class="bg-white border-b border-gray-200 mb-8">
        <div class="container mx-auto px-4 py-3 flex gap-4 items-center">
            <a class="font-black text-xl text-gray-800 mr-4" asp-controller="Home" asp-action="Index">
                Articles<span class="text-blue-600">App</span>
            </a>

            <div class="flex gap-2">
                @await Html.PartialAsync("_NavLink", ("Home", "Index", "Home", "bi-house-door", false))
                @await Html.PartialAsync("_NavLink", ("Articles", "Index", "Articles", "bi-file-earmark-text", false))
                @await Html.PartialAsync("_NavLink", ("Products", "Index", "Products", "bi-cart", false))
            </div>
        </div>
    </nav>

    <div class="container mx-auto px-4">
        @RenderBody()
    </div>

</body>
</html>
