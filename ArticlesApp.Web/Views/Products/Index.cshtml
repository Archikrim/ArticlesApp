@model List<Product>
@{
    ViewData["Title"] = "Products";
}

<h1 class="text-3xl font-black text-gray-900 mb-8">Our Products</h1>
<form asp-action="Sync" method="post">
    <button type="submit"
            class="mb-6 px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition">
        Sync Products
    </button>
</form>
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    @foreach (var p in Model)
    {
        <div class="bg-white rounded-2xl p-4 shadow-sm border border-gray-100 hover:shadow-xl transition-all duration-300 flex flex-col group">
            <div class="relative bg-gray-50 rounded-xl p-6 mb-4 overflow-hidden">
                <img src="@p.Image" class="h-48 w-full object-contain group-hover:scale-110 transition-transform duration-500" />
            </div>

            <h2 class="font-bold text-gray-800 text-lg line-clamp-1 mb-1">@p.Title</h2>
            <div class="flex items-center justify-between mt-auto pt-4">
                <p class="text-2xl font-black text-green-600">$@p.Price</p>
                <a asp-action="Details" asp-route-id="@p.Id"
                   class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center text-gray-600 hover:bg-blue-600 hover:text-white transition-all">
                    <i class="bi bi-eye-fill"></i>
                </a>
            </div>
        </div>
    }
</div>
@if (ViewBag.TotalPages > 1)
{
    <div class="mt-12 flex justify-center items-center gap-2">

        @if (ViewBag.Page > 1)
        {
            <a asp-action="Index" asp-route-page="@(ViewBag.Page - 1)"
               class="p-2 w-10 h-10 flex items-center justify-center bg-white border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors text-gray-600 shadow-sm">
                <i class="bi bi-chevron-left"></i>
            </a>
        }
        else
        {
            <span class="p-2 w-10 h-10 flex items-center justify-center bg-gray-50 border border-gray-100 rounded-lg text-gray-300 cursor-not-allowed">
                <i class="bi bi-chevron-left"></i>
            </span>
        }

        <span class="px-4 py-2 bg-blue-600 text-white rounded-lg font-bold shadow-sm shadow-blue-200">
            @ViewBag.Page <span class="text-blue-200 font-normal mx-1 text-xs">of</span> @ViewBag.TotalPages
        </span>

        @if (ViewBag.Page < ViewBag.TotalPages)
        {
            <a asp-action="Index" asp-route-page="@(ViewBag.Page + 1)"
               class="p-2 w-10 h-10 flex items-center justify-center bg-white border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors text-gray-600 shadow-sm">
                <i class="bi bi-chevron-right"></i>
            </a>
        }
        else
        {
            <span class="p-2 w-10 h-10 flex items-center justify-center bg-gray-50 border border-gray-100 rounded-lg text-gray-300 cursor-not-allowed">
                <i class="bi bi-chevron-right"></i>
            </span>
        }
    </div>
}